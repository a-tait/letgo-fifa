PORT=3000
JWT_SECRET=change-me-to-a-long-random-string

# API-Football (api-sports.io) — free tier ~100 req/day
APIFOOTBALL_KEY=

# Guardian Open Platform — free key at https://open-platform.theguardian.com/
GUARDIAN_KEY=

# Reddit API — create an app at https://www.reddit.com/prefs/apps
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
REDDIT_USER_AGENT=pitch26/0.1 by your_reddit_username

# WC26 competition ID on API-Football (verify on their /leagues endpoint)
WC26_LEAGUE_ID=1
